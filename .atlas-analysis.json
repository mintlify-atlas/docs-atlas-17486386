  "keyFeatures": [
    "Lightweight routing with static and dynamic path support",
    "Flexible middleware pipeline (global and route-specific)",
    "Route modules for organizing and namespacing routes",
    "Custom request/response abstractions with helper methods",
    "Built-in middlewares for logging, timeouts, and error handling",
    "TypeScript support with full type definitions"
  ],
  "publicApiSurface": [
    "asi - Main server instance",
    "url - Route manager for adding routes",
    "RouteModule - Class for creating modular route groups",
    "MiddlewarePipeline - Middleware management system",
    "addPath() - Add routes with optional methods and handlers",
    "setup() - Configure server port and base path",
    "run() - Start the HTTP server",
    "createRouteModule() - Create nested route modules",
    "addMiddleware() - Register global middlewares",
    "sendJson() - Send JSON responses",
    "sendText() - Send text responses"
  ]
